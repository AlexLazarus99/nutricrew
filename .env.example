# Local development — copy to .env and set BOT_TOKEN when ready for Telegram

NODE_ENV=development

# Set real token from @BotFather (required on Render for Telegram bot + auth)
BOT_TOKEN=
# Without @ — used for invite links (https://t.me/BOT_USERNAME?startapp=...)
BOT_USERNAME=
# Social links (shown in app when set)
SOCIAL_TELEGRAM_CHANNEL=
SOCIAL_TELEGRAM_GROUP=
SOCIAL_INSTAGRAM=
SOCIAL_X=
SOCIAL_YOUTUBE=
SOCIAL_TIKTOK=
DEV_SKIP_BOT=true
DEV_BYPASS_AUTH=true

WEBAPP_URL=http://localhost:5173
# Optional: extra CORS origins, comma-separated (e.g. https://nutricrew-miniapp.vercel.app)
# CORS_ORIGINS=
PORT=3000
BOT_MODE=polling

# Local Postgres (default)
DATABASE_URL=postgresql://postgres:nutricrew@127.0.0.1:5432/nutricrew

# Neon (production on Render) — Neon Dashboard → Connection details → Pooled connection:
# Must include ?sslmode=require . Wake idle projects at console.neon.tech first.
# Optional DIRECT_URL = Direct connection (no -pooler); migrations auto-strip -pooler if omitted.
# DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
# DIRECT_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Claude (photo + voice + barcode AI) — https://console.anthropic.com
ANTHROPIC_API_KEY=
CLAUDE_VISION_MODEL=claude-sonnet-4-6
CLAUDE_TEXT_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
VISION_MODEL=gpt-4o-mini
# Free tier fallback — https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_VISION_MODEL=gemini-2.5-flash

S3_ENABLED=false
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=nutricrew
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_PUBLIC_URL=http://localhost:9000/nutricrew

PREMIUM_STARS_PRICE=99
PREMIUM_DAYS=30
MIN_POOL_FUND_STARS=10
MAX_POOL_FUND_STARS=1000
WINNER_POOL_SHARE_PERCENT=80

# Free trial length for new users (hours)
APP_TRIAL_HOURS=24
# Permanent Pro + full app access for these Telegram usernames (comma-separated, no @)
ADMIN_TELEGRAM_USERNAMES=ingritoo
# Optional numeric Telegram user IDs (comma-separated)
# ADMIN_TELEGRAM_IDS=
# Tribute → Pro in mini app (Creator dashboard → Settings → API Keys)
TRIBUTE_API_KEY=
# Comma-separated subscription IDs from Tribute (Pro channel). Empty = legacy: all subscriptions grant Pro.
# TRIBUTE_PRO_SUBSCRIPTION_IDS=123456
# LiteCrew channel subscription IDs (monthly lite access). Required for channel payments after trial.
# TRIBUTE_LITE_CREW_SUBSCRIPTION_IDS=789012
# TRIBUTE_PRO_DAYS=30
# TRIBUTE_LITE_CREW_DAYS=30
# Ссылки на подписки Pro в Tribute (через запятую, если несколько)
TRIBUTE_PRO_URL=https://t.me/tribute/app?startapp=ep_8xu227KkHfYz8ptLQJWsBaCLxHdPT3mHVdOhOTNE59ruNXvQnV,https://t.me/tribute/app?startapp=ep_8xu22rXBIwrLAW3OZI1UFoDzmaIvDjZCFE3WV6d39Z1hY6fIuq

PRO_STARS_PRICE=149
PRO_DAYS=30

REMINDER_HOUR_UTC=8
CRON_ENABLED=false
