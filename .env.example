# Local development — copy to .env and set BOT_TOKEN when ready for Telegram

NODE_ENV=development

# Set real token from @BotFather (required on Render for Telegram bot + auth)
BOT_TOKEN=
# Without @ — used for invite links (https://t.me/BOT_USERNAME?startapp=...)
BOT_USERNAME=
# Social links (shown in app when set)
SOCIAL_TELEGRAM_CHANNEL=
SOCIAL_TELEGRAM_GROUP=
SOCIAL_INSTAGRAM=
SOCIAL_X=
SOCIAL_YOUTUBE=
SOCIAL_TIKTOK=
DEV_SKIP_BOT=true
DEV_BYPASS_AUTH=true

WEBAPP_URL=http://localhost:5173
# Optional: extra CORS origins, comma-separated (e.g. https://nutricrew-miniapp.vercel.app)
# CORS_ORIGINS=
PORT=3000
BOT_MODE=polling

# Local Postgres (default)
DATABASE_URL=postgresql://postgres:nutricrew@127.0.0.1:5432/nutricrew

# Neon (production on Render) — Neon Dashboard → Connection details → Pooled connection:
# Must include ?sslmode=require . Wake idle projects at console.neon.tech first.
# Optional DIRECT_URL = Direct connection (no -pooler); migrations auto-strip -pooler if omitted.
# DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
# DIRECT_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

OPENAI_API_KEY=
VISION_MODEL=gpt-4o-mini
# Free tier fallback — https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_VISION_MODEL=gemini-2.0-flash

S3_ENABLED=false
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=nutricrew
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_PUBLIC_URL=http://localhost:9000/nutricrew

PREMIUM_STARS_PRICE=99
PREMIUM_DAYS=30
MIN_POOL_FUND_STARS=10
MAX_POOL_FUND_STARS=1000
WINNER_POOL_SHARE_PERCENT=80

REMINDER_HOUR_UTC=8
CRON_ENABLED=false
