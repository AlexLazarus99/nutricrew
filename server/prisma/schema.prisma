generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  billingEmail String?  @map("billing_email") @db.VarChar(256)
  seatLimit    Int      @default(50) @map("seat_limit")
  createdAt    DateTime @default(now()) @map("created_at")

  teams   Team[]
  members OrgMember[]

  @@map("organizations")
}

model OrgMember {
  organizationId String   @map("organization_id") @db.Uuid
  userId         BigInt   @map("user_id")
  role           String   @default("admin") @db.VarChar(16)
  joinedAt       DateTime @default(now()) @map("joined_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([organizationId, userId])
  @@map("org_members")
}

model Team {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String
  inviteCode       String   @unique @map("invite_code") @db.VarChar(12)
  weeklyGoalType   String   @default("points") @map("weekly_goal_type") @db.VarChar(32)
  weeklyGoalTarget Int      @default(1000) @map("weekly_goal_target")
  isPremium        Boolean  @default(false) @map("is_premium")
  premiumUntil     DateTime? @map("premium_until")
  leagueTag        String?  @map("league_tag") @db.VarChar(32)
  organizationId   String?  @map("organization_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at")

  organization     Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  users            User[]
  members          TeamMember[]
  meals            Meal[]
  weeklyScores     WeeklyTeamScore[]
  prizePools       PrizePool[]
  chatMessages     ChatMessage[]
  challengeProgress TeamChallengeProgress[]
  duels            TeamDuel[]
  recipes          TeamRecipe[]

  @@index([organizationId])
  @@map("teams")
}

model User {
  id            BigInt    @id @default(autoincrement())
  telegramId    BigInt    @unique @map("telegram_id")
  firstName     String    @map("first_name")
  lastName      String?   @map("last_name")
  username      String?
  locale        String    @default("en") @db.VarChar(5)
  currentStreak Int       @default(0) @map("current_streak")
  longestStreak Int       @default(0) @map("longest_streak")
  lastMealDate  DateTime? @map("last_meal_date") @db.Date
  teamId        String?   @map("team_id") @db.Uuid
  starBalance   Int       @default(0) @map("star_balance")
  weightKg      Float?    @map("weight_kg")
  heightCm      Int?      @map("height_cm")
  age           Int?      @map("age")
  timezoneOffsetMinutes Int? @map("timezone_offset_minutes")
  referredByUserId      BigInt? @map("referred_by_user_id")
  streakFreezes         Int      @default(0) @map("streak_freezes")
  leagueTier            String   @default("bronze") @map("league_tier") @db.VarChar(16)
  weeklyLeagueXp        Int      @default(0) @map("weekly_league_xp")
  dailyGoalType         String   @default("meals") @map("daily_goal_type") @db.VarChar(16)
  dailyGoalTarget       Int      @default(3) @map("daily_goal_target")
  stepsGoal             Int      @default(8000) @map("steps_goal")
  photoPrivacy          String   @default("team") @map("photo_privacy") @db.VarChar(16)
  birdBoostUntil        DateTime? @map("bird_boost_until")
  selectedBirdId        String   @default("classic") @map("selected_bird_id") @db.VarChar(32)
  doublePointsWeekKey   String?  @map("double_points_week_key") @db.VarChar(10)
  onboardingVariant     String   @default("team_first") @map("onboarding_variant") @db.VarChar(16)
  isPro                 Boolean  @default(false) @map("is_pro")
  proUntil              DateTime? @map("pro_until")
  createdAt     DateTime  @default(now()) @map("created_at")

  referredBy        User?  @relation("UserReferrals", fields: [referredByUserId], references: [id], onDelete: SetNull)
  analyticsEvents   AnalyticsEvent[]
  referrals         User[] @relation("UserReferrals")
  team              Team?              @relation(fields: [teamId], references: [id], onDelete: SetNull)
  dailyBonuses      UserDailyBonus[]
  questClaims       UserQuestClaim[]
  chatMessages      ChatMessage[]
  chatReactions     ChatReaction[]
  teamMemberships   TeamMember[]
  meals             Meal[]
  mealKudos         MealKudos[]
  favoriteMeals     FavoriteMeal[]
  payments          Payment[]
  starTransactions  StarTransaction[]
  prizeAwards       PrizeAward[]
  birdGameBest      BirdGameBest?
  birdGameDaily     BirdGameDaily[]
  birdGameUpgrades  BirdGameUpgrade?
  birdGameGhostRuns BirdGameGhostRun[]
  ownedBirds        UserBird[]
  birdTrials        UserBirdTrial[]
  xpSpends          UserXpSpend[]
  achievements      UserAchievement[]
  battlePass        BattlePassProgress?
  duelsAsChallenger TeamDuel[] @relation("DuelChallenger")
  duelsAsOpponent   TeamDuel[] @relation("DuelOpponent")
  weightLogs        WeightLog[]
  waterLogs         WaterLog[]
  dailyStepTotals   DailyStepTotal[]
  workoutLogs       WorkoutLog[]
  orgMemberships    OrgMember[]
  recipeVotes       TeamRecipeVote[]
  wearableImports   WearableImport[]

  @@index([teamId])
  @@index([referredByUserId])
  @@map("users")
}

model UserDailyBonus {
  userId    BigInt   @map("user_id")
  bonusType String   @map("bonus_type") @db.VarChar(16)
  bonusDate DateTime @map("bonus_date") @db.Date

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, bonusType, bonusDate])
  @@map("user_daily_bonuses")
}

model UserQuestClaim {
  userId      BigInt   @map("user_id")
  questId     String   @map("quest_id") @db.VarChar(64)
  periodKey   String   @map("period_key") @db.VarChar(16)
  rewardXp    Int      @default(0) @map("reward_xp")
  rewardTeam  Int      @default(0) @map("reward_team")
  rewardStars Int      @default(0) @map("reward_stars")
  claimedAt   DateTime @default(now()) @map("claimed_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, questId, periodKey])
  @@map("user_quest_claims")
}

model ChatMessage {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  teamId       String   @map("team_id") @db.Uuid
  userId       BigInt?  @map("user_id")
  authorName   String   @map("author_name") @db.VarChar(128)
  body         String   @db.VarChar(500)
  isHidden     Boolean  @default(false) @map("is_hidden")
  hiddenReason String?  @map("hidden_reason") @db.VarChar(64)
  isSystem     Boolean  @default(false) @map("is_system")
  createdAt    DateTime @default(now()) @map("created_at")

  team      Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  reactions ChatReaction[]

  @@index([teamId, createdAt])
  @@map("chat_messages")
}

model ChatReaction {
  messageId String   @map("message_id") @db.Uuid
  userId    BigInt   @map("user_id")
  emoji     String   @db.VarChar(16)
  createdAt DateTime @default(now()) @map("created_at")

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([messageId, userId, emoji])
  @@map("chat_reactions")
}

model BirdGameBest {
  userId      BigInt   @id @map("user_id")
  score       Int
  level       Int      @default(1)
  fruits      Int      @default(0)
  displayName String   @map("display_name")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([score(sort: Desc)])
  @@map("bird_game_bests")
}

model BirdGameDaily {
  userId    BigInt   @map("user_id")
  dayKey    String   @map("day_key") @db.VarChar(10)
  bestScore Int      @default(0) @map("best_score")
  claimed   Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, dayKey])
  @@map("bird_game_daily")
}

model BirdGameUpgrade {
  userId        BigInt @id @map("user_id")
  ghostLevel    Int    @default(0) @map("ghost_level")
  gapLevel      Int    @default(0) @map("gap_level")
  nearMissLevel Int    @default(0) @map("near_miss_level")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("bird_game_upgrades")
}

model BirdGameGhostRun {
  id          BigInt   @id @default(autoincrement())
  userId      BigInt   @map("user_id")
  displayName String   @map("display_name")
  birdId      String   @map("bird_id") @db.VarChar(32)
  score       Int
  samples     Json
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([score(sort: Desc)])
  @@map("bird_game_ghost_runs")
}

model UserBird {
  userId     BigInt   @map("user_id")
  birdId     String   @map("bird_id") @db.VarChar(32)
  unlockedAt DateTime @default(now()) @map("unlocked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, birdId])
  @@map("user_birds")
}

model UserBirdTrial {
  userId        BigInt   @map("user_id")
  trialId       String   @map("trial_id") @db.VarChar(64)
  levelReached  Int      @map("level_reached")
  completedAt   DateTime @default(now()) @map("completed_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, trialId])
  @@map("user_bird_trials")
}

model UserXpSpend {
  userId      BigInt   @map("user_id")
  spendType   String   @map("spend_type") @db.VarChar(32)
  referenceId String   @map("reference_id") @db.VarChar(64)
  amount      Int
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, spendType, referenceId])
  @@map("user_xp_spends")
}

model TeamMember {
  teamId   String   @map("team_id") @db.Uuid
  userId   BigInt   @map("user_id")
  role     String   @default("member") @db.VarChar(16)
  joinedAt DateTime @default(now()) @map("joined_at")

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([teamId, userId])
  @@map("team_members")
}

model Meal {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       BigInt   @map("user_id")
  teamId       String?  @map("team_id") @db.Uuid
  description  String
  calories     Int
  protein      Int      @default(0)
  carbs        Int      @default(0)
  fat          Int      @default(0)
  points       Int
  photoUrl     String?  @map("photo_url")
  photoKey     String?  @map("photo_key")
  aiSource     String?  @map("ai_source") @db.VarChar(32)
  aiConfidence Float?   @map("ai_confidence")
  mealSlot     String?  @map("meal_slot") @db.VarChar(16)
  qualityTag   String?  @map("quality_tag") @db.VarChar(16)
  imageHash    String?  @map("image_hash") @db.VarChar(64)
  verificationStatus String @default("ok") @map("verification_status") @db.VarChar(16)
  kudosCount   Int      @default(0) @map("kudos_count")
  fiberG       Float?   @map("fiber_g")
  sugarG       Float?   @map("sugar_g")
  sodiumMg     Float?   @map("sodium_mg")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team? @relation(fields: [teamId], references: [id], onDelete: SetNull)
  kudos MealKudos[]

  @@index([userId, createdAt])
  @@index([teamId, createdAt])
  @@index([userId, imageHash])
  @@index([userId, deletedAt])
  @@map("meals")
}

model WeightLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    BigInt   @map("user_id")
  kg        Float
  loggedAt  DateTime @default(now()) @map("logged_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, loggedAt])
  @@map("weight_logs")
}

model WaterLog {
  id      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId  BigInt   @map("user_id")
  ml      Int
  logDate DateTime @map("log_date") @db.Date
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, logDate])
  @@map("water_logs")
}

model DailyStepTotal {
  userId           BigInt    @map("user_id")
  logDate          DateTime  @map("log_date") @db.Date
  steps            Int       @default(0)
  stepsXpGranted   Int       @default(0) @map("steps_xp_granted")
  healthSource     String?   @map("health_source") @db.VarChar(32)
  lastHealthSyncAt DateTime? @map("last_health_sync_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, logDate])
  @@index([userId, logDate])
  @@map("daily_step_totals")
}

model WorkoutLog {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          BigInt   @map("user_id")
  logDate         DateTime @map("log_date") @db.Date
  workoutType     String   @map("workout_type") @db.VarChar(24)
  durationMinutes Int      @map("duration_minutes")
  distanceKm      Float?   @map("distance_km")
  steps           Int      @default(0)
  createdAt       DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, logDate])
  @@map("workout_logs")
}

model FoodSearchCache {
  queryKey  String   @id @map("query_key") @db.VarChar(128)
  locale    String   @db.VarChar(5)
  results   Json
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  @@map("food_search_cache")
}

model TeamRecipe {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  teamId      String   @map("team_id") @db.Uuid
  authorId    BigInt   @map("author_id")
  title       String   @db.VarChar(128)
  description String   @db.VarChar(1000)
  calories    Int      @default(0)
  protein     Int      @default(0)
  carbs       Int      @default(0)
  fat         Int      @default(0)
  voteCount   Int      @default(0) @map("vote_count")
  createdAt   DateTime @default(now()) @map("created_at")

  team  Team             @relation(fields: [teamId], references: [id], onDelete: Cascade)
  votes TeamRecipeVote[]

  @@index([teamId, voteCount(sort: Desc)])
  @@map("team_recipes")
}

model TeamRecipeVote {
  recipeId  String   @map("recipe_id") @db.Uuid
  userId    BigInt   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  recipe TeamRecipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([recipeId, userId])
  @@map("team_recipe_votes")
}

model WearableImport {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    BigInt   @map("user_id")
  source    String   @db.VarChar(32)
  payload   Json
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("wearable_imports")
}

model WebAuthToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String   @db.VarChar(256)
  token     String   @unique @db.VarChar(64)
  userId    BigInt?  @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@map("web_auth_tokens")
}

model AnalyticsEvent {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt?  @map("user_id")
  eventName String   @map("event_name") @db.VarChar(64)
  props     Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventName, createdAt])
  @@index([userId, createdAt])
  @@map("analytics_events")
}

model VisionCache {
  imageHash String   @map("image_hash") @db.VarChar(64)
  locale    String   @db.VarChar(5)
  result    Json
  hitCount  Int      @default(0) @map("hit_count")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@id([imageHash, locale])
  @@map("vision_cache")
}

model MealKudos {
  mealId    String   @map("meal_id") @db.Uuid
  userId    BigInt   @map("user_id")
  emoji     String   @default("🔥") @db.VarChar(8)
  createdAt DateTime @default(now()) @map("created_at")

  meal Meal @relation(fields: [mealId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([mealId, userId])
  @@map("meal_kudos")
}

model FavoriteMeal {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      BigInt   @map("user_id")
  description String
  calories    Int
  protein     Int      @default(0)
  carbs       Int      @default(0)
  fat         Int      @default(0)
  useCount    Int      @default(0) @map("use_count")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("favorite_meals")
}

model TeamChallengeProgress {
  teamId      String    @map("team_id") @db.Uuid
  challengeId String    @map("challenge_id") @db.VarChar(32)
  weekKey     String    @map("week_key") @db.VarChar(10)
  progress    Int       @default(0)
  target      Int
  completedAt DateTime? @map("completed_at")

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@id([teamId, challengeId, weekKey])
  @@map("team_challenge_progress")
}

model TeamDuel {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  teamId           String   @map("team_id") @db.Uuid
  challengerId     BigInt   @map("challenger_id")
  opponentId       BigInt   @map("opponent_id")
  weekKey          String   @map("week_key") @db.VarChar(10)
  challengerPoints Int      @default(0) @map("challenger_points")
  opponentPoints   Int      @default(0) @map("opponent_points")
  status           String   @default("active") @db.VarChar(16)
  createdAt        DateTime @default(now()) @map("created_at")

  team       Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  challenger User @relation("DuelChallenger", fields: [challengerId], references: [id], onDelete: Cascade)
  opponent   User @relation("DuelOpponent", fields: [opponentId], references: [id], onDelete: Cascade)

  @@index([teamId, weekKey])
  @@map("team_duels")
}

model UserAchievement {
  userId        BigInt   @map("user_id")
  achievementId String   @map("achievement_id") @db.VarChar(32)
  unlockedAt    DateTime @default(now()) @map("unlocked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, achievementId])
  @@map("user_achievements")
}

model BattlePassProgress {
  userId    BigInt   @id @map("user_id")
  seasonKey String   @map("season_key") @db.VarChar(10)
  tier      Int      @default(0)
  xp        Int      @default(0)
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("battle_pass_progress")
}

model WeeklyTeamScore {
  teamId   String @map("team_id") @db.Uuid
  weekKey  String @map("week_key") @db.VarChar(10)
  points   Int    @default(0)

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@id([teamId, weekKey])
  @@map("weekly_team_scores")
}

model PrizePool {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  teamId           String   @map("team_id") @db.Uuid
  weekKey          String   @map("week_key") @db.VarChar(10)
  starsTotal       Int      @default(0) @map("stars_total")
  starsDistributed Int      @default(0) @map("stars_distributed")
  createdAt        DateTime @default(now()) @map("created_at")

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, weekKey])
  @@map("prize_pools")
}

model Payment {
  id                        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                    BigInt   @map("user_id")
  teamId                    String?  @map("team_id") @db.Uuid
  payload                   String   @unique
  paymentType               String   @map("payment_type") @db.VarChar(32)
  referenceId               String?  @map("reference_id") @db.VarChar(64)
  starsAmount               Int      @map("stars_amount")
  status                    String   @default("pending") @db.VarChar(16)
  telegramPaymentChargeId   String?  @map("telegram_payment_charge_id")
  createdAt                 DateTime @default(now()) @map("created_at")
  completedAt               DateTime? @map("completed_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model PrizeAward {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      BigInt    @map("user_id")
  teamId      String    @map("team_id") @db.Uuid
  weekKey     String    @map("week_key") @db.VarChar(10)
  starsAmount Int       @map("stars_amount")
  status      String    @default("credited") @db.VarChar(16)
  createdAt   DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, weekKey])
  @@map("prize_awards")
}

model StarTransaction {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      BigInt   @map("user_id")
  amount      Int
  type        String   @db.VarChar(32)
  referenceId String?  @map("reference_id")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("star_transactions")
}
