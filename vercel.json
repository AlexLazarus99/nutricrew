{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm ci",
  "buildCommand": "npm run build -w miniapp",
  "outputDirectory": "miniapp/dist",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://nutricrew-dddi.onrender.com/api/$1"
    },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
